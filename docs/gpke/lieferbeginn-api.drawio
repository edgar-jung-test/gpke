          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- (5) NB → LFN: respondToRegistration POST (confirmation or rejection) -->
        <mxCell id="arr-5ok" edge="1" parent="1" source="nb-respond" target="lfn-end-ok"
