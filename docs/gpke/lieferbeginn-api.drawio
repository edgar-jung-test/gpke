          vertex="1" edge="0">
          <mxGeometry x="900" y="470" width="280" height="30" as="geometry" />
        </mxCell>

        <!-- (4) LFA → NB: respondToDeregistrationRequest POST -->
        <mxCell id="arr-4" edge="1" parent="1" source="lfa-respond" target="nb-dereg"
          style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#0050ef;exitX=0;exitY=0.75;exitDx=0;exitDy=0;entryX=1;entryY=0.75;entryDx=0;entryDy=0;">
