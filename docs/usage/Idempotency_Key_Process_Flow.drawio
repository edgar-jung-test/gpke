    <mxCell id="rules_bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
      <mxGeometry x="860" y="388" width="920" height="200" as="geometry" />
