    <mxCell id="fs_error_note" value="⚠ Auch Fehler-Antworten (4xx) werden gecacht!&#10;Für korrigierte Anfrage: neuen Idempotency-Key verwenden!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3cd;strokeColor=#ff9800;fontSize=9;fontStyle=1;" vertex="1" parent="1">
