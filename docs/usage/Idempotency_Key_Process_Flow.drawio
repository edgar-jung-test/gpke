    <mxCell id="i80" value="💡  Nur Idempotency-Key hat AKTIVE serverseitige Deduplizierung — die anderen Header sind rein observational!
    Only Idempotency-Key has ACTIVE server-side deduplication — other headers are observational only!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontColor=#bf360c;fontSize=9;align=left;spacingLeft=6;" vertex="1"    parent="1"><mxGeometry  x="20" y="347" width="810" height="44"  as="geometry"></mxGeometry></mxCell>
    <mxCell id="r81" value="Client-Implementierungsregeln / Client Implementation Rules" style="text;html=1;fontSize=11;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1"    parent="1"><mxGeometry  x="20" y="401" width="500" height="20"  as="geometry"></mxGeometry></mxCell>
    <mxCell id="ru82" value="1.  UUID v4 VOR dem 1. Versuch generieren — NICHT vor jedem Retry  /  Generate UUID v4 BEFORE the 1st attempt — NOT before each retry" style="text;html=1;fontSize=9;fontColor=#2e7d32;fillColor=none;strokeColor=none;align=left;" vertex="1"    parent="1"><mxGeometry  x="20" y="423" width="810" height="17"  as="geometry"></mxGeometry></mxCell>
    <mxCell id="ru83" value="2.  Key bei ALLEN Retries identisch lassen  /  Keep key IDENTICAL across ALL retries" style="text;html=1;fontSize=9;fontColor=#2e7d32;fillColor=none;strokeColor=none;align=left;" vertex="1"    parent="1"><mxGeometry  x="20" y="441" width="810" height="17"  as="geometry"></mxGeometry></mxCell>
    <mxCell id="ru84" value="3.  Key NIEMALS für verschiedene Operationen wiederverwenden  /  NEVER reuse key across different operations" style="text;html=1;fontSize=9;fontColor=#c62828;fillColor=none;strokeColor=none;align=left;" vertex="1"    parent="1"><mxGeometry  x="20" y="459" width="810" height="17"  as="geometry"></mxGeometry></mxCell>
    <mxCell id="ru85" value="4.  Neuen Key generieren wenn Request-Body korrigiert wird  /  Use a NEW key when correcting the request body" style="text;html=1;fontSize=9;fontColor=#c62828;fillColor=none;strokeColor=none;align=left;" vertex="1"    parent="1"><mxGeometry  x="20" y="477" width="810" height="17"  as="geometry"></mxGeometry></mxCell>
    <mxCell id="ru86" value="5.  Exponentiellen Backoff mit Jitter: 2s → 4s → 8s → 16s (max. 5–10 Versuche)  /  Exponential backoff with jitter" style="text;html=1;fontSize=9;fontColor=#1565c0;fillColor=none;strokeColor=none;align=left;" vertex="1"    parent="1"><mxGeometry  x="20" y="495" width="810" height="17"  as="geometry"></mxGeometry></mxCell>
    <mxCell id="ru87" value="6.  Retry-After Header beachten (503/429)  /  Always respect Retry-After response header" style="text;html=1;fontSize=9;fontColor=#1565c0;fillColor=none;strokeColor=none;align=left;" vertex="1"    parent="1"><mxGeometry  x="20" y="513" width="810" height="17"  as="geometry"></mxGeometry></mxCell>
    <mxCell id="ru88" value="7.  409 Conflict = IN_PROGRESS: warten, keinen neuen Key generieren  /  Wait — do NOT create new key" style="text;html=1;fontSize=9;fontColor=#7b1fa2;fillColor=none;strokeColor=none;align=left;" vertex="1"    parent="1"><mxGeometry  x="20" y="531" width="810" height="17"  as="geometry"></mxGeometry></mxCell>
    <mxCell id="ru89" value="8.  Idempotency-Key-Status: replayed als gültige, maßgebliche Antwort akzeptieren  /  Accept replayed as authoritative" style="text;html=1;fontSize=9;fontColor=#7b1fa2;fillColor=none;strokeColor=none;align=left;" vertex="1"    parent="1"><mxGeometry  x="20" y="549" width="810" height="17"  as="geometry"></mxGeometry></mxCell>
