    <mxCell id="rules_title" value="Client-Implementierungsregeln / Client Implementation Rules" style="text;html=1;fontStyle=1;fontSize=11;align=left;" vertex="1" parent="1">
      <mxGeometry x="870" y="396" width="500" height="22" as="geometry" />
    </mxCell>
    
    <mxCell id="rule_0" value="1.  UUID v4 VOR dem ersten Versuch generieren — nicht vor jedem Retry / Generate UUID v4 BEFORE first attempt — NOT before each retry" style="text;html=1;fontSize=9;fontColor=#27ae60;align=left;" vertex="1" parent="1">
      <mxGeometry x="870" y="420" width="900" height="18" as="geometry" />
    </mxCell>
    
    <mxCell id="rule_1" value="2.  Key bei ALLEN Retries IDENTISCH lassen / Keep key IDENTICAL across ALL retries" style="text;html=1;fontSize=9;fontColor=#27ae60;align=left;" vertex="1" parent="1">
      <mxGeometry x="870" y="440" width="900" height="18" as="geometry" />
    </mxCell>
    
    <mxCell id="rule_2" value="3.  Key NIEMALS für verschiedene Operationen wiederverwenden / NEVER reuse key across different operations" style="text;html=1;fontSize=9;fontColor=#c0392b;align=left;" vertex="1" parent="1">
      <mxGeometry x="870" y="460" width="900" height="18" as="geometry" />
    </mxCell>
    
    <mxCell id="rule_3" value="4.  Neuen Key generieren wenn Request-Body korrigiert wird / Generate NEW key when request body is corrected" style="text;html=1;fontSize=9;fontColor=#c0392b;align=left;" vertex="1" parent="1">
      <mxGeometry x="870" y="480" width="900" height="18" as="geometry" />
    </mxCell>
    
    <mxCell id="rule_4" value="5.  Exponentiellen Backoff implementieren: 2s → 4s → 8s → 16s (mit Jitter) / Implement exponential backoff: 2s → 4s → 8s → 16s (with jitter)" style="text;html=1;fontSize=9;fontColor=#1e4d8c;align=left;" vertex="1" parent="1">
      <mxGeometry x="870" y="500" width="900" height="18" as="geometry" />
    </mxCell>
    
    <mxCell id="rule_5" value="6.  Retry-After Header beachten (503/429) / Respect Retry-After header" style="text;html=1;fontSize=9;fontColor=#1e4d8c;align=left;" vertex="1" parent="1">
      <mxGeometry x="870" y="520" width="900" height="18" as="geometry" />
    </mxCell>
    
    <mxCell id="rule_6" value="7.  409 Conflict = IN_PROGRESS: Warten, keinen neuen Key generieren / 409 Conflict = wait, do NOT generate new key" style="text;html=1;fontSize=9;fontColor=#7d6608;align=left;" vertex="1" parent="1">
      <mxGeometry x="870" y="540" width="900" height="18" as="geometry" />
    </mxCell>
    
    <mxCell id="rule_7" value="8.  Idempotency-Key-Status: replayed als gültige Antwort akzeptieren / Accept replayed status as authoritative response" style="text;html=1;fontSize=9;fontColor=#7d6608;align=left;" vertex="1" parent="1">
      <mxGeometry x="870" y="560" width="900" height="18" as="geometry" />
    </mxCell>
  
      </root>
    </mxGraphModel>
  </diagram>
