        <mxCell id="201" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontColor=#bf360c;fontSize=9;align=left;spacingLeft=8;" value="💡  Only Idempotency-Key has ACTIVE server-side deduplication — the other headers are purely observational!" vertex="1">
          <mxGeometry height="36" width="730" x="20" y="328" as="geometry" />
        </mxCell>
        <mxCell id="202" parent="1" style="text;html=1;fontSize=11;fontStyle=1;strokeColor=none;fillColor=none;" value="Client Implementation Rules" vertex="1">
          <mxGeometry height="20" width="400" x="20" y="374" as="geometry" />
        </mxCell>
        <mxCell id="203" parent="1" style="text;html=1;fontSize=9;fontColor=#2e7d32;strokeColor=none;fillColor=none;align=left;" value="1.  Generate UUID v4 BEFORE the 1st attempt — NOT before each retry" vertex="1">
          <mxGeometry height="17" width="730" x="20" y="396" as="geometry" />
        </mxCell>
        <mxCell id="204" parent="1" style="text;html=1;fontSize=9;fontColor=#2e7d32;strokeColor=none;fillColor=none;align=left;" value="2.  Keep key IDENTICAL across ALL retries of the same operation" vertex="1">
          <mxGeometry height="17" width="730" x="20" y="414" as="geometry" />
        </mxCell>
        <mxCell id="205" parent="1" style="text;html=1;fontSize=9;fontColor=#c62828;strokeColor=none;fillColor=none;align=left;" value="3.  NEVER reuse key across different operations" vertex="1">
          <mxGeometry height="17" width="730" x="20" y="432" as="geometry" />
        </mxCell>
        <mxCell id="206" parent="1" style="text;html=1;fontSize=9;fontColor=#c62828;strokeColor=none;fillColor=none;align=left;" value="4.  Generate a NEW key when correcting the request body" vertex="1">
          <mxGeometry height="17" width="730" x="20" y="450" as="geometry" />
        </mxCell>
        <mxCell id="207" parent="1" style="text;html=1;fontSize=9;fontColor=#1565c0;strokeColor=none;fillColor=none;align=left;" value="5.  Implement exponential backoff with jitter: 2s → 4s → 8s → 16s (max. 5–10 attempts)" vertex="1">
          <mxGeometry height="17" width="730" x="20" y="468" as="geometry" />
        </mxCell>
        <mxCell id="208" parent="1" style="text;html=1;fontSize=9;fontColor=#1565c0;strokeColor=none;fillColor=none;align=left;" value="6.  Always respect Retry-After response header (503 / 429)" vertex="1">
          <mxGeometry height="17" width="730" x="20" y="486" as="geometry" />
        </mxCell>
        <mxCell id="209" parent="1" style="text;html=1;fontSize=9;fontColor=#7b1fa2;strokeColor=none;fillColor=none;align=left;" value="7.  409 Conflict = key IN_PROGRESS: wait, do NOT generate a new key" vertex="1">
          <mxGeometry height="17" width="730" x="20" y="504" as="geometry" />
        </mxCell>
        <mxCell id="210" parent="1" style="text;html=1;fontSize=9;fontColor=#7b1fa2;strokeColor=none;fillColor=none;align=left;" value="8.  Accept Idempotency-Key-Status: replayed as the authoritative response" vertex="1">
          <mxGeometry height="17" width="730" x="20" y="522" as="geometry" />
        </mxCell>
