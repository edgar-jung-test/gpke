    <mxCell id="201" value="💡  Only Idempotency-Key has ACTIVE server-side deduplication — the other headers are purely observational!" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#e65100;fontColor=#bf360c;fontSize=9;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="20" y="328" width="730" height="36" as="geometry"/></mxCell>
    <mxCell id="202" value="Client Implementation Rules" style="text;html=1;fontSize=11;fontStyle=1;strokeColor=none;fillColor=none;" vertex="1" parent="1"><mxGeometry x="20" y="374" width="400" height="20" as="geometry"/></mxCell>
    <mxCell id="203" value="1.  Generate UUID v4 BEFORE the 1st attempt — NOT before each retry" style="text;html=1;fontSize=9;fontColor=#2e7d32;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="20" y="396" width="730" height="17" as="geometry"/></mxCell>
    <mxCell id="204" value="2.  Keep key IDENTICAL across ALL retries of the same operation" style="text;html=1;fontSize=9;fontColor=#2e7d32;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="20" y="414" width="730" height="17" as="geometry"/></mxCell>
    <mxCell id="205" value="3.  NEVER reuse key across different operations" style="text;html=1;fontSize=9;fontColor=#c62828;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="20" y="432" width="730" height="17" as="geometry"/></mxCell>
    <mxCell id="206" value="4.  Generate a NEW key when correcting the request body" style="text;html=1;fontSize=9;fontColor=#c62828;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="20" y="450" width="730" height="17" as="geometry"/></mxCell>
    <mxCell id="207" value="5.  Implement exponential backoff with jitter: 2s → 4s → 8s → 16s (max. 5–10 attempts)" style="text;html=1;fontSize=9;fontColor=#1565c0;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="20" y="468" width="730" height="17" as="geometry"/></mxCell>
    <mxCell id="208" value="6.  Always respect Retry-After response header (503 / 429)" style="text;html=1;fontSize=9;fontColor=#1565c0;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="20" y="486" width="730" height="17" as="geometry"/></mxCell>
    <mxCell id="209" value="7.  409 Conflict = key IN_PROGRESS: wait, do NOT generate a new key" style="text;html=1;fontSize=9;fontColor=#7b1fa2;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="20" y="504" width="730" height="17" as="geometry"/></mxCell>
    <mxCell id="210" value="8.  Accept Idempotency-Key-Status: replayed as the authoritative response" style="text;html=1;fontSize=9;fontColor=#7b1fa2;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="20" y="522" width="730" height="17" as="geometry"/></mxCell>
    <mxCell id="211" value="Server Decision Logic" style="text;html=1;fontSize=12;fontStyle=1;strokeColor=none;fillColor=none;align=left;" vertex="1" parent="1"><mxGeometry x="790" y="52" width="340" height="20" as="geometry"/></mxCell>
